# /etc/degenff/env — template. Copy to /etc/degenff/env, chown root:deadplug,
# chmod 0640. The systemd units reference this file via EnvironmentFile=.

# Postgres connection string. Local-socket or TCP both work; the app pools.
DATABASE_URL=postgres://degenff:CHANGE_ME@127.0.0.1:5432/degenff

# Auth.js v5 secret. Generate with: openssl rand -base64 48
AUTH_SECRET=CHANGE_ME

# Canonical site URL. Auth.js uses this for OAuth callbacks.
AUTH_URL=https://your.domain.com

NODE_ENV=production

# Discord application (https://discord.com/developers/applications):
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# Guild + channel IDs (right-click in Discord with Developer Mode on → Copy ID):
DISCORD_GUILD_ID=
DISCORD_MOD_QUEUE_CHANNEL_ID=
DISCORD_SHOWCASE_CHANNEL_ID=
DISCORD_FEATS_CHANNEL_ID=

# Doorman (welcome bot) — leave blank to disable the auto-greeting.
DISCORD_WELCOME_CHANNEL_ID=

# Steno (on-the-record quotes) — leave blank to disable. The emoji defaults
# to 📋 if unset; override with any standard emoji (custom emojis not
# supported by this comparison — would need :name: handling.)
DISCORD_QUOTE_CHANNEL_ID=
DISCORD_QUOTE_EMOJI=📋

# Audit log mirror (every mod action gets a one-line embed posted here).
# Recommended: a mod-only channel. Leave blank to disable.
DISCORD_AUDIT_CHANNEL_ID=

# Scheduled posts. Leave either blank to disable.
#   DIGEST: weekly digest, Saturday 4am UTC (this-week counts)
#   DROP:   random oracle line every 3–6 hours
DISCORD_DIGEST_CHANNEL_ID=
DISCORD_DROP_CHANNEL_ID=

# Verification gate (anti-raid). Bot needs "Manage Roles" permission and
# its highest role must sit ABOVE @verified in the role hierarchy. Channel
# permissions are configured Discord-side: @everyone sees only #verify;
# @verified unlocks the rest of the server. Run /setup-verify once after
# setting these to post the gate.
DISCORD_VERIFY_CHANNEL_ID=
DISCORD_VERIFIED_ROLE_ID=

# Roles that map to site roles. Anyone with DISCORD_ADMIN_ROLE_ID gets
# users.role='admin'; DISCORD_MOD_ROLE_ID gets 'mod'. Everyone else is
# 'contributor'.
DISCORD_MOD_ROLE_ID=
DISCORD_ADMIN_ROLE_ID=

# Optional fallback if you don't enable the public widget on the Discord
# server. Use a permanent (no-expiry, no-max-uses) invite URL.
DISCORD_INVITE_URL=
